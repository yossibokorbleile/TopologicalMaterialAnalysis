RADII = 0.389, 0.718, 0.635, 1.491
REPEAT_X = 3
REPEAT_Y = 3
REPEAT_Z = 3

[LPS]
ATOMS = Li, P, S
RADII = 0.76, 1.05, 1.80
REPEAT_X = 1
REPEAT_Y = 1
REPEAT_Z = 1
@endcode

@section ex_csv Example 7: Saving and Loading Persistence Diagrams

@code{.py}
import sys
sys.path.insert(0, "src")

import pandas
import oineus
from toma_functions import (
    read_configuration, sample_at, oineus_process,
    write_dgm_csv, calculate_APF
)

# Load and process
atoms, radii, _, _, _, repeat_x, repeat_y, repeat_z = \
    read_configuration("examples/settings.ini", "ZIF")

points = sample_at(
    file_path="examples/ZIF_test.xyz",
    format="xyz",
    sample_index=0,
    repeat_x=repeat_x,
    repeat_y=repeat_y,
    repeat_z=repeat_z,
    atom_list=atoms,
    radius_list=radii
)

params = oineus.ReductionParams()
params.n_threads = 4

dcmp, filt, dgm_0, dgm_1, dgm_2 = oineus_process(points, params)

# Save persistence diagrams as CSV
write_dgm_csv(dgm_0, "output/ZIF_sample_0_PD_0")
write_dgm_csv(dgm_1, "output/ZIF_sample_0_PD_1")
write_dgm_csv(dgm_2, "output/ZIF_sample_0_PD_2")

# Load a previously saved diagram
loaded_dgm = pandas.read_csv("output/ZIF_sample_0_PD_1.csv", index_col=0)
apf = calculate_APF(loaded_dgm)

print(f"Loaded diagram with {len(loaded_dgm)} points")
print(f"APF total: {apf['lifetime'].iloc[-1]:.4f}")
@endcode
